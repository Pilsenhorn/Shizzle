---
const { concert } = Astro.props;
---

<div
  id="concert-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 px-4"
>
  <div
    class="w-full max-w-md rounded-2xl border border-white/10 bg-zinc-900 p-8 shadow-2xl"
  >
    <p class="text-sm uppercase tracking-[0.2em] text-white/60">
      Upcoming concert
    </p>

    <h2 class="mt-3 text-3xl font-bold">
      {concert.data.city}
    </h2>

    <p class="mt-2 text-white/80">
      {concert.data.venue}
    </p>

    <p class="mt-1 text-white/60">
      {concert.data.date}
    </p>

    <div class="mt-6 flex gap-3">
      <a
        href={concert.data.ticketUrl ?? "#"}
        class="rounded-xl border border-white/20 px-4 py-2 hover:bg-white hover:text-black transition"
      >
        Vstupenky
      </a>

      <button
        id="close-modal"
        class="rounded-xl border border-white/10 px-4 py-2 hover:bg-white/20 transition"
      >
        Zavřít
      </button>
    </div>
  </div>
</div>