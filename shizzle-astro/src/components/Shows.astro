---
import type { CollectionEntry } from "astro:content";

interface Props {
  concerts: CollectionEntry<"concerts">[];
}

const { concerts } = Astro.props;
---

<section id="shows" class="py-(--space-lg)">
  <div class="mx-auto max-w-3xl space-y-(--space-sm) px-(--space-sm) text-left">

    {concerts.map((show) => {
      const date = new Date(show.data.date);

      return (
        <article class="grid gap-(--space-sm) border-b border-(--text-primary)/10 pb-(--space-sm) sm:grid-cols-[1fr_auto] sm:items-end">

          <div>
            <p class="text-sm text-(--text-muted)">
              {date.toLocaleDateString("cs-CZ", {
                day: "numeric",
                month: "long",
                year: "numeric",
              })}
            </p>

            <p class="font-medium">
              {show.data.city}
            </p>

            <p class="text-sm text-(--text-muted)">
              {show.data.venue}
            </p>
          </div>

          <div class="flex flex-wrap gap-(--space-sm)">
            <a
              href={`/concerts/${show.id}/`}
              class="text-sm underline-offset-2 hover:underline"
            >
              Detail
            </a>

            {show.data.ticketUrl && (
              <a
                href={show.data.ticketUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm underline-offset-2 hover:underline"
              >
                Vstupenky
              </a>
            )}
          </div>

        </article>
      );
    })}

  </div>
</section>
